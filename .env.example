# LLM Provider API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Target LLM Configuration (the model being tested)
TARGET_PROVIDER=anthropic
TARGET_MODEL=claude-sonnet-4-20250514

# Attacker LLM Configuration (model generating attacks)
ATTACKER_PROVIDER=anthropic
ATTACKER_MODEL=claude-sonnet-4-20250514

# Red Team Configuration
MAX_ATTACK_ATTEMPTS=10
REPORT_OUTPUT_DIR=reports/output
